# GitHub contributions graph (About page)
# Create a token at https://github.com/settings/tokens (classic, no scopes needed
# for public contribution data) and put it in .env.local (not committed).
GITHUB_USERNAME=mountstorm
GITHUB_PERSONAL_ACCESS_TOKEN=

# Contact form email delivery
# Sign up free at https://resend.com, grab an API key from
# https://resend.com/api-keys, and put it in .env.local (not committed).
# Without a verified custom domain, Resend only allows sending to the email
# address you signed up with — that's fine here since mail goes to you.
RESEND_API_KEY=
